# 复制为 .env：cp docker/env.example docker/.env ，再按你的服务器修改
# 部署前请先在仓库根目录打包：
# ./mvnw -pl xiaohe-admin -am package -DskipTests

# MySQL（与容器网络可达的地址：本机库用 host.docker.internal；远端用 IP/域名）
#
# 端口：Docker 一般是「宿主机端口:容器内端口」。
#   - 若是 3307:3306（常见，外面连 3307），这里填 DB_PORT=3307
#   - 若是 3306:3307（外面连 3306），这里填 DB_PORT=3306
# 应用要填的是「能连上的那个宿主机端口」（上面写法里的左边那个）。
DB_HOST=host.docker.internal
DB_PORT=3306
DB_NAME=xiaohe
DB_USERNAME=root
DB_PASSWORD=你的数据库密码

# Redis
REDIS_HOST=host.docker.internal
REDIS_PORT=6379
# REDIS_PASSWORD=

# 应用
APP_HOST_PORT=8002
# 对外访问根地址（文件 URL 前缀等，填你的域名或 http://服务器IP:8002）
XIAOHE_FILE_URL=http://localhost:8002
